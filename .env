DATABASE_URL="file:./db/custom.db"

# ─── App URL ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Admin / Secret Keys ─────────────────────────────────────────────────────
ADMIN_API_SECRET="dev-secret"
GOLD_PRICE_UPDATE_SECRET="dev-secret"

# ─── Gold Price APIs ──────────────────────────────────────────────────────────
# Primary: GoldAPI.io — returns exact EGP per gram per karat, no conversion needed
GOLDAPI_KEY="goldapi-5pumsmmj7nv4u-io"

# Fallback: MetalpriceAPI — used automatically if GoldAPI is down
METALPRICEAPI_KEY="853c9e2371423501046927dfd611d248"

# ─── Manual Override (optional) ──────────────────────────────────────────────
# Uncomment to force a specific 24K price per gram in EGP, bypassing both APIs
# GOLD_BASE_PRICE_OVERRIDE=8617

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS="http://localhost:3000"
