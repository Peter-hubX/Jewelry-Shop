{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext",
      "webworker"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    // ── Old/backup files ─────────────────────────────────────────────────────
    "src/app/page-old.tsx",       // archived backup, not part of the live app
    // ── Mobile React Native app (separate tsconfig scope) ────────────────────
    "michiel-jewelry-app",
    "index.tsx",                  // React Native / Expo root entry — not web
    // ── Test infrastructure (managed by Playwright, not tsc) ─────────────────
    "seed.spec.ts",
    "specs",
    // ── Build artefacts ───────────────────────────────────────────────────────
    ".next",
    "out",
    "build"
  ]
}